---
import '../styles/global.css'
import Header from '../components/header.astro'
import Footer from '../components/footer.astro';

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>BreakCookies - Inicio</title>
	</head>
	<body>
		<Header />
		<main>
			<h1>Bienvenidos a BreakCookies</h1>
			<p style="text-align: center; margin-top: 16px;">Repostería artesanal hecha con amor</p>
			<section style="margin-top: 48px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
				<div style="background: var(--color-gray); border-radius: 12px; padding: 24px; text-align: center;">
					<h3 style="color: var(--color-orange);">🥐 Repostería</h3>
					<p style="margin-top: 8px; font-size: 0.9rem;">Croissants, galletas y brownies horneados cada mañana</p>
				</div>
				<div style="background: var(--color-gray); border-radius: 12px; padding: 24px; text-align: center;">
					<h3 style="color: var(--color-orange);">☕ Cafetería</h3>
					<p style="margin-top: 8px; font-size: 0.9rem;">Café de especialidad y bebidas artesanales</p>
				</div>
				<div style="background: var(--color-gray); border-radius: 12px; padding: 24px; text-align: center;">
					<h3 style="color: var(--color-orange);">🍮 Postres</h3>
					<p style="margin-top: 8px; font-size: 0.9rem;">Postres caseros con ingredientes frescos</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
